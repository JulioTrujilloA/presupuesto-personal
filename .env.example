# Copia este archivo a .env y rellena con tus valores reales.
# El .env real está en .gitignore — nunca lo subas al repo.

# Proyecto Supabase
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# El parser de PDFs corre en la Edge Function 'analizar-estado', que se llama
# con supabase.functions.invoke — no necesita variable en el cliente.
# La API key de Anthropic se configura como SECRETO de la función, no aquí:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...   (o desde el dashboard)
