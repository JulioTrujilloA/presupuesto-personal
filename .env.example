# Copia este archivo a .env y rellena con tus valores reales.
# El .env real está en .gitignore — nunca lo subas al repo.

# Proyecto Supabase
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Endpoint del parser de PDFs (Edge Function de Supabase).
# Si se omite, importacion.js cae al placeholder de api.anthropic.com (no usar en prod).
VITE_ANALYZE_ENDPOINT=https://TU-PROYECTO.supabase.co/functions/v1/analizar-estado
